generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ProjectStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
}

model User {
  id        String    @id @default(cuid())
  fullName  String
  email     String    @unique
  password  String

  projects  Project[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id          String         @id @default(cuid())
  projectName String
  description String
  status      ProjectStatus

  startDate   DateTime
  endDate     DateTime

  userId      String
  user        User           @relation(fields: [userId], references: [id])

  tasks       Task[]

  createdAt   DateTime       @default(now())
}

model Task {
  id          String       @id @default(cuid())
  taskName    String
  description String

  priority    TaskPriority
  status      TaskStatus

  dueDate     DateTime

  projectId   String
  project     Project      @relation(fields: [projectId], references: [id])

  createdAt   DateTime     @default(now())
}